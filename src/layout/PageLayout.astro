---
const { title } = Astro.props;
import "../styles/global.css";
import { Header } from "../components/Header.jsx";
import Grids from "../components/Grids.astro";
---

<html>
  <head>
    <title>{title}</title>
  </head>
  <body>
    <Grids />
    <main class="relative">
      <Header client:load />
      <slot />
    </main>
  </body>
</html>
